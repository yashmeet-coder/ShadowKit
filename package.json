{
  "name": "shadow-dom-widget",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "description": "An embeddable widget scaffold built with React, shadcn/ui and Shadow DOM. Ships a minimal feedback widget as a demo.",
  "scripts": {
    "dev": "vite --host --port 3000",
    "build": "npm run build:css && vite build",
    "lint": "eslint .",
    "preview": "vite preview",
    "build:css": "tailwindcss -i ./src/index.css -o ./src/styles.css",
    "dev:css": "tailwindcss -i ./src/index.css -o ./src/styles.css --watch"
  },
  "dependencies": {
    "@radix-ui/react-dialog": "^1.1.6",
    "@radix-ui/react-label": "^2.1.2",
    "@radix-ui/react-slot": "^1.1.2",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "construct-style-sheets-polyfill": "^3.1.0",
    "lucide-react": "^0.475.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-responsive": "^10.0.0",
    "react-shadow": "^20.6.0",
    "tailwind-merge": "^3.0.1",
    "tailwindcss-animate": "^1.0.7"
  },
  "devDependencies": {
    "@eslint/js": "^9.19.0",
    "@types/react": "^18.3.1",
    "@types/react-dom": "^18.3.1",
    "@vitejs/plugin-react": "^4.3.4",
    "autoprefixer": "^10.4.20",
    "eslint": "^9.19.0",
    "eslint-plugin-react": "^7.37.4",
    "eslint-plugin-react-hooks": "^5.0.0",
    "eslint-plugin-react-refresh": "^0.4.18",
    "globals": "^15.14.0",
    "postcss": "^8.5.1",
    "tailwindcss": "^3.4.17",
    "vite": "^6.1.0",
    "vite-plugin-css-injected-by-js": "^3.5.2"
  }
}
